---
import Layout from '../layouts/Layout.astro';
---

<Layout title="why are you here?">
	
	<main>

		<h1>
            hiii
		</h1>
        <p>
            if you found this then you looked through the source or used dirb or smth, im impressed! <br>
            either way there is a reason you are looking for this, right? <br>
            maybe there is something you want to hear from me, something you want to tell me, or maybe you want to get some sense of closure.. <br>
        </p>
        <p>
            <a href="https://files.catbox.moe/nwcy0a.txt">click here</a> <br>
        </p>
	</main>
	

</Layout>

<style>
	body {
		color: var(--text);
		background-color: var(--base);
		font-family: Inter, Avenir, Helvetica, Arial, sans-serif;
		text-align: left;
		width: 100%;
  		display: flex;
		justify-content: center;

	}
	main {
		margin: 0;
		padding: 1rem;
		font-size: 20px;
		line-height: 1.6;
	}
	h1 {
		font-size: 4rem;
		font-weight: 700;
		line-height: 1;
		margin-bottom: 1rem;
	}
	h2 {
		font-size: 2.4rem;
		font-weight: 600;
	}
	p {
		color: var(--subtext1);
		font-size: 1.6rem;
		font-weight: 400;
	}
	header {
		margin: 0;
		padding: 1rem;
	}
	a {
		color: var(--accent);
	}

	a:link, a:visited {
		text-decoration: none;
	}

	a:hover, a:active {
		text-decoration: underline;
	}
</style>