</Layout>

<style>
	hr.solid{
		border: 3px solid var(--accent);
		border-radius: 2px;
	}
	body {
		color: var(--text);
		background-color: var(--base);
		font-family: Inter, Avenir, Helvetica, Arial, sans-serif;
		text-align: left;
		width: 70%;
  		display: flex;
		justify-content: center;
		max-width: 1920px;
		margin: auto;
	}
	main {
		margin: 0;
		padding: 1rem;
		font-size: 20px;
		line-height: 1.6;
	}
	h1 {
		font-size: 4rem;
		font-weight: 700;
		line-height: 1;
		margin-bottom: 1rem;
	}
	h2 {
		font-size: 2.4rem;
		font-weight: 600;
	}
	p {
		color: var(--subtext1);
		font-size: 1.6rem;
		font-weight: 400;
	}
	header {
		margin: 0;
		padding: 1rem;
	}
	a {
		color: var(--accent);
		transition: text-decoration 1.5s ease;
	}

	a:link, a:visited {
		text-decoration: none;
	}

	a:hover, a:active {
		text-decoration: underline;
	}
</style>
























